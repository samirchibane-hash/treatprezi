# ─── Frontend (Vite) ────────────────────────────────────────────────────────
# These go in your local .env file
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# ─── Supabase Edge Function Secrets ─────────────────────────────────────────
# Set these in: Supabase Dashboard → Project → Edge Functions → Secrets
# (Do NOT put secret keys in .env — they are server-side only)

# Stripe — use test key for dev, live key for production
STRIPE_TEST_SECRET_KEY=sk_test_...
STRIPE_SECRET_KEY=sk_live_...

# Nutrient — for HTML → PDF generation (generate-contract function)
NUTRIENT_API_KEY=your-nutrient-api-key

# ─── Gamma (via N8n) ─────────────────────────────────────────────────────────
# Gamma is triggered indirectly via an N8n webhook in PresentationStep.tsx
# No API key needed here — manage the Gamma connection inside your N8n workflow
# N8n webhook URL is hardcoded in: src/components/proposal/wizard/PresentationStep.tsx
